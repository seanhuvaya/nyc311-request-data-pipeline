# Base URL of the backend API. Vite bakes this in at build time, so set it
# before running `npm run build` or pass it as a docker build-arg.
#
# Local dev (with backend running on host):
#   VITE_API_URL=http://localhost:8000
#
# Production:
#   VITE_API_URL=https://api.nyc311.seanhuvaya.dev
VITE_API_URL=http://localhost:8000
